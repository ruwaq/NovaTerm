# Release signing config for NovaTerm.
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties — it's in .gitignore.
#
# Generate a keystore:
#   keytool -genkey -v -keystore novaterm-release.keystore \
#     -alias novaterm -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=novaterm-release.keystore
storePassword=
keyAlias=novaterm
keyPassword=
