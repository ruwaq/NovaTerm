# LFS
app/src/main/assets/bootstrap-aarch64.zip filter=lfs diff=lfs merge=lfs -text

# Linguist overrides — show Kotlin and Rust as primary languages
# Legacy Termux Java code is vendored (not counted in language stats)
*.kt linguist-detectable=true
*.rs linguist-detectable=true
core/terminal-emulator/** linguist-vendored=true
core/terminal-view/** linguist-vendored=true

# Binary files
*.so binary
*.zip binary
*.apk binary
*.png binary
*.jpg binary
*.webp binary

# Normalize line endings
* text=auto
*.kt text eol=lf
*.java text eol=lf
*.rs text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.properties text eol=lf
