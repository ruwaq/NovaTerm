# NovaTerm Android Keystore Configuration
# This file must NOT be committed to Git. Use keystore.properties.example as a template.
# For local development, use the existing keystore.properties (already in .gitignore).
# For CI, set environment variables instead.

# Path to the keystore file
storeFile=/path/to/your/release.keystore

# Keystore password (use env var KEYSTORE_PASSWORD in CI)
# storePassword=your_keystore_password

# Key alias
keyAlias=novaterm

# Key password (use env var KEY_PASSWORD in CI)
# keyPassword=your_key_password